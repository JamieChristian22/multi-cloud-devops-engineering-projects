resource "aws_security_group" "alb" { name="${var.name}-alb-sg"; description="Public web traffic to the ALB"; vpc_id=var.vpc_id; ingress { description="HTTP"; from_port=80; to_port=80; protocol="tcp"; cidr_blocks=["0.0.0.0/0"] }; egress { from_port=0; to_port=0; protocol="-1"; cidr_blocks=["0.0.0.0/0"] }; tags=merge(var.tags,{Name="${var.name}-alb-sg"}) }
resource "aws_security_group" "ecs" { name="${var.name}-ecs-sg"; description="Only ALB traffic reaches ECS tasks"; vpc_id=var.vpc_id; ingress { description="Application traffic from ALB"; from_port=var.container_port; to_port=var.container_port; protocol="tcp"; security_groups=[aws_security_group.alb.id] }; egress { from_port=0; to_port=0; protocol="-1"; cidr_blocks=["0.0.0.0/0"] }; tags=merge(var.tags,{Name="${var.name}-ecs-sg"}) }
